    },
    {
      "id": "fv_7iWzV45QT8g1EKhTrr",
      "type": "text",
      "x": 3667.3973978296376,
      "y": 2654.4502310670996,
      "width": 497.05791285976466,
      "height": 380,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1k",
      "roundness": null,
      "seed": 833290569,
      "version": 2128,
      "versionNonce": 926569929,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782665544245,
      "link": null,
      "locked": false,
      "text": "Zoo keeper basically assignes each server a particular\nID range, this is how uniqueness is ensured currently.\n\nAgain if this is a SPOF multiple instances of Zookeeper\ncan be maintained\n\nIf a zookeeper fails the moment request comes, that\nrange is dropped and the next range is assigned when it\nbecomes available again. since we have around 3.5\nTrillion available unique URLs this is enough even if a\n1 mil range is dropped.\n\n\nAlso the Zookeeper will have less frequent calls to\nsince a server will only reach out to it when its 1 mil\nrange is over. Unlike in case of count cache where the\nserver just reaches out for each id causing collisions.\n\nServers have seperate pools assigned to pick from.",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Zoo keeper basically assignes each server a particular ID range, this is how uniqueness is ensured currently.\n\nAgain if this is a SPOF multiple instances of Zookeeper can be maintained\n\nIf a zookeeper fails the moment request comes, that range is dropped and the next range is assigned when it becomes available again. since we have around 3.5 Trillion available unique URLs this is enough even if a 1 mil range is dropped.\n\n\nAlso the Zookeeper will have less frequent calls to since a server will only reach out to it when its 1 mil range is over. Unlike in case of count cache where the server just reaches out for each id causing collisions.\n\nServers have seperate pools assigned to pick from.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "namSWrEFF7NPdFNzJWmEQ",
      "type": "text",
      "x": 2160.92274284397,
      "y": 4271.928469704803,
      "width": 384.9998474121094,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1l",
      "roundness": null,
      "seed": 1848682825,
      "version": 1030,
      "versionNonce": 237242601,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782666013474,
      "link": null,
      "locked": false,
      "text": "Additional Considerations",
      "fontSize": 28,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Additional Considerations",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "3NQfnK57DQVAbX54dl4ky",
      "type": "text",
      "x": 2163.796043325164,
      "y": 4312.3200366451365,
      "width": 935,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1m",
      "roundness": null,
      "seed": 784242729,
      "version": 1734,
      "versionNonce": 1369650151,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782666053884,
      "link": null,
      "locked": false,
      "text": "-> Analytics\nCounts for each URL to determine which short URL to cache\nIP address to store location information to determine where to locate the caches etc.\n\n\n-> Rate Limiting\nTo prevent DDOS attacks\n\n\n-> Security Considerations\nAdd random suffix to the short URL to prevent hackers from predicting the URLs\nNote - This is a tradeoff to the URL length to prevent the predictability",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "-> Analytics\nCounts for each URL to determine which short URL to cache\nIP address to store location information to determine where to locate the caches etc.\n\n\n-> Rate Limiting\nTo prevent DDOS attacks\n\n\n-> Security Considerations\nAdd random suffix to the short URL to prevent hackers from predicting the URLs\nNote - This is a tradeoff to the URL length to prevent the predictability",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "EGFVEm8yYDnWIci9njidA",
      "type": "text",
      "x": 624.5168506113941,
      "y": 4125.803610447965,
      "width": 461.99981689453125,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
