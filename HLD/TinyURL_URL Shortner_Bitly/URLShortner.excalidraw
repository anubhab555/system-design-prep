      "seed": 1080765865,
      "version": 136,
      "versionNonce": 1739901223,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782665085165,
      "link": null,
      "locked": false,
      "text": "CDN Discussion",
      "fontSize": 28,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "CDN Discussion",
      "autoResize": true,
