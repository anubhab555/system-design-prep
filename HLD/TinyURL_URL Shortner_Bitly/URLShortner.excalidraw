    },
    {
      "id": "7HNdzEcnLDvWOBbsLAnGY",
      "type": "text",
      "x": 620.9932805861414,
      "y": 3870.5351506613724,
      "width": 638,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1f",
      "roundness": null,
      "seed": 1089025095,
      "version": 358,
      "versionNonce": 765581257,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782666042737,
      "link": null,
      "locked": false,
      "text": "Using one means requests never hit the backend -> 301 case\nWe won't kow if our service is working\n\nIf we care about analytics, logging etc. Lets not use CDN",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Using one means requests never hit the backend -> 301 case\nWe won't kow if our service is working\n\nIf we care about analytics, logging etc. Lets not use CDN",
      "autoResize": true,
      "lineHeight": 1.25
    },
