      "roundness": null,
      "seed": 540170799,
      "version": 1053,
      "versionNonce": 1912527015,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782649753170,
      "link": null,
      "locked": false,
      "text": "Trade off discussion\n\n301 -> Permanent \nWhere we store the generated url in a cache for future\nuse, no regeneration, no scaling of the server, always\nhits the cache, less compute cost, no analytics\n\n302 -> Temporary\nAnalytics can be done, requests hit the server and we\ncan analyse the frequently queried, cost involved, more\nservers needed\n\n302 is best here cause even if we don't show the users\nthe analytics, we track this internally, if something\nbroke we can debug easily",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Trade off discussion\n\n301 -> Permanent \nWhere we store the generated url in a cache for future use, no regeneration, no scaling of the server, always hits the cache, less compute cost, no analytics\n\n302 -> Temporary\nAnalytics can be done, requests hit the server and we can analyse the frequently queried, cost involved, more servers needed\n\n302 is best here cause even if we don't show the users the analytics, we track this internally, if something broke we can debug easily",
      "autoResize": false,
      "lineHeight": 1.25
    },
