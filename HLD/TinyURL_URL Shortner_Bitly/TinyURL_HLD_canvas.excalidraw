    {
      "id": "requirements",
      "type": "text",
      "x": 62.83227644660235,
      "y": 134.92847834782202,
      "width": 297.37218504030807,
      "height": 216,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#f8f9fa",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
