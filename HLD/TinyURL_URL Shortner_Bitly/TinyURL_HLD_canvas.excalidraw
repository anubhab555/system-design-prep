    {
      "id": "KoEgyADYb063-3ylf2RnW",
      "type": "text",
      "x": 946.8521477062044,
      "y": 2253.405351452851,
      "width": 630.895751953125,
      "height": 315,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
