      "seed": 1882377636,
      "version": 593,
      "versionNonce": 2064617756,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782629567752,
      "link": null,
      "locked": false,
      "text": "1. Request comes to generate a short URL\n\n2. Request is checked in cache \n\n3. Server gets the range from the Zoo Keeper\n\n4. Saves it to the DB and updates the cache\n\n5. returns to the user.",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Request comes to generate a short URL\n\n2. Request is checked in cache \n\n3. Server gets the range from the Zoo Keeper\n\n4. Saves it to the DB and updates the cache\n\n5. returns to the user.",
      "autoResize": true,
      "lineHeight": 1.25
    },
