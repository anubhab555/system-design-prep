      "containerId": null,
      "originalText": "Count cache approach",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "wE4WkLiTX9wv5nkZY-RRa",
      "type": "text",
      "x": 1959.31941365479,
      "y": 394.53080394217864,
      "width": 497.05791285976466,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aK",
      "roundness": null,
      "seed": 1938090916,
      "version": 474,
      "versionNonce": 1471125404,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782629539117,
      "link": null,
      "locked": false,
      "text": "This is a SPOF and if the cache is down\nfunctionality goes down\n\nEven if multiple caches and web servers are\ngenerated this will create further complications\nlike collisions\n\nServer A got the ID 10, while Server B was\nrequesting at the same time and got the ID 10\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "This is a SPOF and if the cache is down functionality goes down\n\nEven if multiple caches and web servers are generated this will create further complications like collisions\n\nServer A got the ID 10, while Server B was requesting at the same time and got the ID 10\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
